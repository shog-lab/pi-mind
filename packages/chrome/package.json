{
  "name": "pi-chrome",
  "version": "0.3.0",
  "description": "Drive Chrome from a pi agent: black-box testing, scraping, and authenticated browser tasks.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "tsc && node ../../tools/copy-static.mjs 'extensions/**/package.json'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepare": "npm run build",
    "postinstall": "node bin/init.js"
  },
  "bin": {
    "pi-chrome-init": "bin/init.js"
  },
  "files": [
    "dist/**",
    "skills/**",
    "bin/**/*.js",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0",
    "agent-browser": "^0.27.0",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
