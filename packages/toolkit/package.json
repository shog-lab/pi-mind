{
  "name": "@shog-lab/pi-toolkit",
  "version": "0.2.3",
  "description": "Common pi-coding-agent extensions: web search + image understanding (mmx), MCP server bridge, sub-agent spawn, browser automation (agent-browser).",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shog-lab/pi-mind.git",
    "directory": "packages/toolkit"
  },
  "homepage": "https://github.com/shog-lab/pi-mind/tree/main/packages/toolkit",
  "bugs": "https://github.com/shog-lab/pi-mind/issues",
  "scripts": {
    "build": "rm -rf dist && tsc && node ../../tools/copy-static.mjs 'extensions/**/package.json'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepare": "npm run build",
    "postinstall": "node bin/init.js"
  },
  "bin": {
    "pi-toolkit-init": "bin/init.js"
  },
  "files": [
    "dist/**",
    "bin/**/*.js",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0",
    "agent-browser": "^0.27.0",
    "@shog-lab/pi-utils": "*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
