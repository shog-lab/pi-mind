#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

PERSONA="shog"
MODEL="${SHOG_MODEL:-openai/gpt-5.5}"
THINKING="${SHOG_THINKING:-high}"
EXCLUDE_TOOLS="${SHOG_EXCLUDE_TOOLS:-}"
NO_SKILLS="${SHOG_NO_SKILLS:-}"

exec "$SCRIPT_DIR/run" "$PERSONA" "$MODEL" "$THINKING" "$EXCLUDE_TOOLS" "$NO_SKILLS" "$@"
