#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

PERSONA="alice"
MODEL="${ALICE_MODEL:-deepseek/deepseek-v4-pro}"
THINKING="${ALICE_THINKING:-high}"
EXCLUDE_TOOLS="${ALICE_EXCLUDE_TOOLS:-}"
NO_SKILLS="${ALICE_NO_SKILLS:-}"

exec "$SCRIPT_DIR/run" "$PERSONA" "$MODEL" "$THINKING" "$EXCLUDE_TOOLS" "$NO_SKILLS" "$@"
