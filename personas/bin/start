#!/usr/bin/env bash
# Internal shared launcher. Prefer personas/bin/alice|bob|carol.

set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: $0 <alice|bob|carol> [extra pi args...]" >&2
  exit 2
fi

PERSONA="$1"
shift

case "$PERSONA" in
  alice|bob|carol) ;;
  *)
    echo "start: unknown persona '$PERSONA' (expected: alice | bob | carol)" >&2
    exit 2
    ;;
esac

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
PROMPT_FILE="$REPO_ROOT/personas/prompts/$PERSONA.md"

if [[ ! -f "$PROMPT_FILE" ]]; then
  echo "start: persona prompt file not found: $PROMPT_FILE" >&2
  exit 3
fi

export PI_AGENT_NAME="${PI_AGENT_NAME:-$PERSONA}"
cd "$REPO_ROOT"

PI_ARGS=(--append-system-prompt "$PROMPT_FILE")

MODEL=""
EXCLUDE_TOOLS=""
NO_SKILLS=""

case "$PERSONA" in
  alice)
    MODEL="${ALICE_MODEL:-deepseek/deepseek-v4-pro}"
    EXCLUDE_TOOLS="${ALICE_EXCLUDE_TOOLS:-}"
    NO_SKILLS="${ALICE_NO_SKILLS:-}"
    ;;
  bob)
    MODEL="${BOB_MODEL:-minimax-cn/MiniMax-M3}"
    EXCLUDE_TOOLS="remember_this,observe,update_memory,mark_memory_audit_complete,create_skill,update_skill"
    if [[ -n "${BOB_EXCLUDE_TOOLS:-}" ]]; then
      EXCLUDE_TOOLS="$EXCLUDE_TOOLS,${BOB_EXCLUDE_TOOLS}"
    fi
    NO_SKILLS="${BOB_NO_SKILLS:-}"
    ;;
  carol)
    MODEL="${CAROL_MODEL:-deepseek/deepseek-v4-pro}"
    EXCLUDE_TOOLS="remember_this,observe,update_memory,mark_memory_audit_complete,create_skill,update_skill"
    if [[ -n "${CAROL_EXCLUDE_TOOLS:-}" ]]; then
      EXCLUDE_TOOLS="$EXCLUDE_TOOLS,${CAROL_EXCLUDE_TOOLS}"
    fi
    NO_SKILLS="${CAROL_NO_SKILLS:-}"
    ;;
esac

if [[ -n "$MODEL" ]]; then
  PI_ARGS+=(--model "$MODEL")
fi

if [[ -n "$EXCLUDE_TOOLS" ]]; then
  PI_ARGS+=(--exclude-tools "$EXCLUDE_TOOLS")
fi

if [[ "$NO_SKILLS" == "1" ]]; then
  PI_ARGS+=(--no-skills)
fi

exec pi "${PI_ARGS[@]}" "$@"
