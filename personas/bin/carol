#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

PERSONA="carol"
MODEL="${CAROL_MODEL:-deepseek/deepseek-v4-pro}"
THINKING="${CAROL_THINKING:-high}"
EXCLUDE_TOOLS="remember_this,observe,update_memory,mark_memory_audit_complete,create_skill,update_skill,schedule_cron,list_cron,remove_cron"
if [[ -n "${CAROL_EXCLUDE_TOOLS:-}" ]]; then
  EXCLUDE_TOOLS="$EXCLUDE_TOOLS,${CAROL_EXCLUDE_TOOLS}"
fi
NO_SKILLS="${CAROL_NO_SKILLS:-}"

exec "$SCRIPT_DIR/run" "$PERSONA" "$MODEL" "$THINKING" "$EXCLUDE_TOOLS" "$NO_SKILLS" "$@"
