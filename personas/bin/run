#!/usr/bin/env bash
# Internal helper. User-facing entrypoint is personas/bin/shog.
# Usage: run <persona> <model> <thinking> <exclude-tools> <no-skills-flag> [extra pi args...]

set -euo pipefail

if [[ $# -lt 5 ]]; then
  echo "Usage: $0 <persona> <model> <thinking> <exclude-tools> <no-skills-flag> [extra pi args...]" >&2
  exit 2
fi

PERSONA="$1"
MODEL="$2"
THINKING="$3"
EXCLUDE_TOOLS="$4"
NO_SKILLS="$5"
shift 5

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
PROMPT_FILE="$REPO_ROOT/personas/prompts/$PERSONA.md"

if [[ ! -f "$PROMPT_FILE" ]]; then
  echo "run: persona prompt file not found: $PROMPT_FILE" >&2
  exit 3
fi

export PI_AGENT_NAME="${PI_AGENT_NAME:-$PERSONA}"
cd "$REPO_ROOT"

PI_ARGS=(--append-system-prompt "$PROMPT_FILE")

if [[ -n "$MODEL" ]]; then
  PI_ARGS+=(--model "$MODEL")
fi

if [[ -n "$THINKING" ]]; then
  PI_ARGS+=(--thinking "$THINKING")
fi

if [[ -n "$EXCLUDE_TOOLS" ]]; then
  PI_ARGS+=(--exclude-tools "$EXCLUDE_TOOLS")
fi

if [[ "$NO_SKILLS" == "1" ]]; then
  PI_ARGS+=(--no-skills)
fi

exec pi "${PI_ARGS[@]}" "$@"
