{
  "name": "pi-mind",
  "version": "0.1.0",
  "description": "Give pi a mind: portable memory and self-evolution as a drop-in pi-coding-agent extension.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint:wiki": "tsx scripts/wiki-lint.ts",
    "verify-feedback": "tsx scripts/verify-feedback.ts",
    "test": "vitest run",
    "postinstall": "node bin/init.js"
  },
  "bin": {
    "pi-mind-init": "bin/init.js",
    "pi-mind-lint": "bin/lint.js",
    "pi-mind-cron": "bin/cron.js"
  },
  "files": [
    "extensions",
    "lib",
    "skills",
    "schema",
    "scripts",
    "bin"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0",
    "better-sqlite3": "^11.8.1",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/proper-lockfile": "^4.1.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
